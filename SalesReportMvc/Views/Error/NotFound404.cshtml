@{
    ViewData["Title"] = "Không tìm thấy trang";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="text-center">
        <!-- Icon -->
        <div class="mb-4">
            <i class="fas fa-search fa-5x text-muted"></i>
        </div>
        
        <!-- Error Code -->
        <h1 class="display-1 fw-bold text-primary">404</h1>
        
        <!-- Title -->
        <h2 class="mb-3 text-gray-800">Không tìm thấy trang</h2>
        
        <!-- Message -->
        <p class="text-muted mb-4">
            Rất tiếc, trang bạn đang tìm kiếm không tồn tại hoặc đã được di chuyển.
        </p>
        
        <!-- Actions -->
        <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
            <a href="javascript:history.back()" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-2"></i> Quay lại
            </a>
            <a href="/report" class="btn btn-primary">
                <i class="fas fa-home me-2"></i> Về trang chủ
            </a>
        </div>
        
        <!-- Additional Links -->
        <div class="mt-5">
            <p class="text-muted small">
                Hoặc truy cập:
                <a href="/report/products" class="text-decoration-none mx-2">
                    <i class="fas fa-box me-1"></i> Báo cáo sản phẩm
                </a>
                |
                <a href="/report/revenue" class="text-decoration-none mx-2">
                    <i class="fas fa-chart-line me-1"></i> Báo cáo doanh thu
                </a>
            </p>
        </div>
    </div>
</div>

<style>
    .min-vh-100 {
        min-height: 100vh;
    }
    
    .text-gray-800 {
        color: #1e293b;
    }
    
    @@media (max-width: 768px) {
        .display-1 {
            font-size: 4rem;
        }
        
        h2 {
            font-size: 1.25rem;
        }
        
        .btn {
            font-size: 0.875rem;
            padding: 0.5rem 1rem;
        }
    }
</style>