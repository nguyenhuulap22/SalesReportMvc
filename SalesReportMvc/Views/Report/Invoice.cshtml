@model List<SalesReport.Reporting.InvoiceReportDto>

@{
    ViewData["Title"] = "Chi tiết hóa đơn";
    var invoice = Model.FirstOrDefault();
    var totalAmount = Model.Sum(x => x.SubTotal);
    var currentOrderCode = Context.Request.RouteValues["orderCode"]?.ToString() ?? invoice?.OrderCode ?? "";
}

<div class="invoice-container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center invoice-header">
        <div>
            <h2 class="invoice-title">
                <i class="fas fa-file-invoice text-primary me-2"></i> Chi tiết hóa đơn
            </h2>
            <p class="invoice-subtitle">Thông tin hóa đơn và chi tiết sản phẩm</p>
        </div>
        <div class="invoice-actions">
            <button id="printBtn" class="btn btn-secondary">
                <i class="fas fa-print me-1"></i> In hóa đơn
            </button>
             <a href="/report/invoice/@(ViewBag.OrderId ?? 1)/export-pdf" class="btn btn-danger">
                <i class="fas fa-file-pdf me-1"></i> Xuất PDF
             </a>
            <a href="/report" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>

    <!-- Invoice Search Component -->
    <div class="invoice-search-card mb-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-8 col-lg-9">
                        <label class="form-label fw-bold text-primary mb-2">
                            <i class="fas fa-search me-1"></i> Tra cứu hóa đơn theo mã
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-primary text-white">
                                <i class="fas fa-hashtag"></i>
                            </span>
                            <input type="text" id="orderSearchInput" class="form-control form-control-lg" 
                                   placeholder="Nhập mã hóa đơn (VD: ORD202501001)" 
                                   value="@currentOrderCode">
                            <button id="searchInvoiceBtn" class="btn btn-primary btn-lg" type="button">
                                <i class="fas fa-eye me-1"></i> Tra cứu
                            </button>
                        </div>
                        <div class="form-text mt-2">
                            <i class="fas fa-info-circle text-info me-1"></i>
                            Nhập <strong>mã hóa đơn</strong> (VD: ORD202501001) để tra cứu chi tiết
                        </div>
                    </div>
                    <div class="col-12 col-md-4 col-lg-3">
                        <div class="bg-light rounded-3 p-3 text-center">
                            <i class="fas fa-file-invoice text-primary fa-2x mb-2"></i>
                            <p class="mb-0 small text-muted">Tra cứu nhanh</p>
                            <div class="mt-2">
                                <button class="btn btn-sm btn-outline-primary quick-code-link" data-code="ORD2025010001">ORD2025010001</button>
                                <button class="btn btn-sm btn-outline-primary quick-code-link mt-1" data-code="ORD2025010002">ORD2025010002</button>
                                <button class="btn btn-sm btn-outline-primary quick-code-link mt-1" data-code="ORD2025010003">ORD2025010003</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Invoice Header Card -->
        <div class="invoice-card">
            <div class="invoice-card-header bg-primary">
                <h5 class="mb-0">
                    <i class="fas fa-receipt me-2"></i> Thông tin hóa đơn
                </h5>
            </div>
            <div class="invoice-card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="info-table">
                            <tr>
                                <td class="fw-bold text-muted">Mã hóa đơn:</td>
                                <td class="fw-bold fs-5 text-primary">@invoice?.OrderCode</td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Ngày lập:</td>
                                <td>@(invoice?.OrderDate.ToString("dd/MM/yyyy HH:mm") ?? "")</td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Trạng thái:</td>
                                <td>
                                    <span class="status-badge">
                                        <i class="fas fa-check-circle me-1"></i> Đã thanh toán
                                    </span>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="info-table">
                            <tr>
                                <td class="fw-bold text-muted">Khách hàng:</td>
                                <td>
                                    <i class="fas fa-user me-1 text-muted"></i>
                                    <strong>@invoice?.CustomerName</strong>
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Nhân viên:</td>
                                <td>
                                    <i class="fas fa-user-tie me-1 text-muted"></i>
                                    @invoice?.EmployeeName
                                </td>
                            </tr>
                            <tr>
                                <td class="fw-bold text-muted">Hình thức:</td>
                                <td>
                                    <i class="fas fa-credit-card me-1 text-muted"></i>
                                    Thanh toán qua chuyển khoản
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Table -->
        <div class="invoice-card">
            <div class="invoice-card-header">
                <h5 class="mb-0">
                    <i class="fas fa-boxes me-2 text-primary"></i> Chi tiết sản phẩm
                </h5>
            </div>
            <div class="invoice-card-body p-0">
                <div class="table-responsive">
                    <table class="products-table">
                        <thead>
                            <tr>
                                <th width="50">STT</th>
                                <th>Sản phẩm</th>
                                <th class="text-center" width="80">SL</th>
                                <th class="text-end" width="120">Đơn giá</th>
                                <th class="text-end" width="100">Giảm giá</th>
                                <th class="text-end" width="120">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int stt = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center text-muted">@stt</td>
                                        <td class="fw-bold">@item.ProductName</td>
                                        <td class="text-center">
                                            <span class="quantity-badge">
                                                <i class="fas fa-times-circle me-1"></i> @item.Quantity
                                            </span>
                                        </td>
                                        <td class="text-end price-regular">@item.UnitPrice.ToString("N0")đ</td>
                                        <td class="text-end price-danger">@item.Discount.ToString("N0")đ</td>
                                        <td class="text-end price-primary">@item.SubTotal.ToString("N0")đ</td>
                                    </tr>
                                    stt++;
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-end fs-5">Tổng cộng:</td>
                                <td class="text-end price-danger fs-4">@totalAmount.ToString("N0")đ</td>
                            </tr>
                            @if (invoice != null && invoice.TotalAmount != totalAmount)
                            {
                                <tr>
                                    <td colspan="5" class="text-end price-text-muted small">(Từ Order: @invoice.TotalAmount.ToString("N0")đ)</td>
                                    <td></td>
                                </tr>
                            }
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Footer Note & Summary -->
        <div class="row">
            <div class="col-md-6">
                <div class="summary-card">
                    <div class="invoice-card-body">
                        <h6><i class="fas fa-info-circle me-2 text-info"></i> Ghi chú:</h6>
                        <p class="text-muted mb-0">Cảm ơn quý khách đã mua hàng tại cửa hàng chúng tôi!</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="summary-card">
                    <div class="invoice-card-body">
                        <div class="summary-row">
                            <span>Tạm tính:</span>
                            <span>@totalAmount.ToString("N0")đ</span>
                        </div>
                        <div class="summary-row">
                            <span>Phí vận chuyển:</span>
                            <span>0đ</span>
                        </div>
                        <div class="summary-divider"></div>
                        <div class="summary-row fw-bold fs-5">
                            <span>Thành tiền:</span>
                            <span class="price-danger">@totalAmount.ToString("N0")đ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Signature -->
        <div class="signature-section">
            <div class="row">
                <div class="col-md-4 signature-item">
                    <p class="signature-label">Người mua hàng</p>
                    <p class="signature-name">(Ký, ghi rõ họ tên)</p>
                </div>
                <div class="col-md-4 signature-item">
                    <p class="signature-label">Người bán hàng</p>
                    <p class="signature-name">@invoice?.EmployeeName</p>
                </div>
                <div class="col-md-4 signature-item">
                    <p class="signature-label">Thủ trưởng đơn vị</p>
                    <p class="signature-name">(Ký, đóng dấu)</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- No Data -->
        <div class="no-data-card">
            <div class="no-data-icon">
                <i class="fas fa-file-invoice"></i>
            </div>
            <h4>Không tìm thấy hóa đơn</h4>
            <p class="text-muted">Vui lòng kiểm tra lại mã hóa đơn</p>
            <div class="mt-3">
                <a href="/report/invoice/1" class="btn btn-primary me-2">
                    <i class="fas fa-eye me-1"></i> Xem hóa đơn #1
                </a>
                <a href="/report" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/invoice.js"></script>
    
    <script>
        $(document).ready(function() {
            // Hàm tìm kiếm theo mã hóa đơn
            function searchByOrderCode() {
                var orderCode = $('#orderSearchInput').val().trim();
                if (orderCode) {
                    window.location.href = '/report/invoice/bycode/' + encodeURIComponent(orderCode);
                } else {
                    alert('Vui lòng nhập mã hóa đơn');
                }
            }
            
            // Search button click
            $('#searchInvoiceBtn').off('click').on('click', searchByOrderCode);
            
            // Enter key press
            $('#orderSearchInput').off('keypress').on('keypress', function(e) {
                if (e.which === 13) {
                    searchByOrderCode();
                }
            });
            
            // Quick code links
            $('.quick-code-link').off('click').on('click', function() {
                var orderCode = $(this).data('code');
                if (orderCode) {
                    window.location.href = '/report/invoice/bycode/' + encodeURIComponent(orderCode);
                }
            });
        });
    </script>
}