@model List<ReportClass.InvoiceReportDto>

<h2>Hóa đơn</h2>

@if (Model.Any())
{
    <p><strong>Mã hóa đơn:</strong> @Model.First().OrderCode</p>
    <p><strong>Ngày:</strong> @Model.First().OrderDate.ToString("dd/MM/yyyy")</p>
    <p><strong>Khách hàng:</strong> @Model.First().CustomerName</p>
    <p><strong>Nhân viên:</strong> @Model.First().EmployeeName</p>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>SL</th>
                <th>Đơn giá</th>
                <th>Giảm giá</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.UnitPrice.ToString("N0")</td>
                    <td>@item.Discount.ToString("N0")</td>
                    <td>@item.SubTotal.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>

    <p><strong>Tổng tiền:</strong> @Model.First().TotalAmount.ToString("N0")</p>
}